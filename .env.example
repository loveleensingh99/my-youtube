# Copy this file to `.env.local` and add your YouTube Data API v3 key.
# Get a free key: https://console.cloud.google.com/apis/credentials

YOUTUBE_API_KEY=your_api_key_here

# Firebase (optional) — sync your personal channel list across devices. No sign-in needed.
# 1. Create a project at https://console.firebase.google.com
# 2. Add a Web app and copy the config values below
# 3. Create Firestore database
# 4. Set NEXT_PUBLIC_FIREBASE_SYNC_KEY to any secret string you choose
# 5. Put the same sync key in firestore.rules, then publish the rules
# 6. Use the same env vars on every device (local + Vercel)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_SYNC_KEY=

# Facebook scraper + Facebook feed (server only — never use NEXT_PUBLIC_*)
# Easiest local setup: download the JSON key and save it as firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# GitHub Actions: paste the full JSON as one line instead
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: Playwright storage state JSON for logged-in Facebook scraping
FACEBOOK_COOKIES_JSON=
