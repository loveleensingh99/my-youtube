# Copy this file to `.env.local` and add your YouTube Data API v3 key.
# Get a free key: https://console.cloud.google.com/apis/credentials

YOUTUBE_API_KEY=your_api_key_here

# Optional on Vercel: create a Blob store in the Vercel dashboard so channels sync
# across devices. Without this, channels are saved in each browser only.
# BLOB_READ_WRITE_TOKEN=
